# ─── Groq API (AI Study Buddy) ────────────────────────────────
# Get a free key at https://console.groq.com/keys
VITE_GROQ_API_KEY=
# Optional: override the model (default below is a good free choice)
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# ─── Firebase (Auth + Firestore) ──────────────────────────────
# Create a project at https://console.firebase.google.com
# Project settings ▸ Your apps ▸ Web app ▸ SDK setup & configuration
# Enable: Authentication ▸ Email/Password + Google, and Firestore Database.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
